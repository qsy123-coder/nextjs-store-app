datasource db {
  provider = "postgresql"
  // 删除 url 和 directUrl 两行
  // 如果你有 shadowDatabaseUrl，也一并删除
}

generator client {
  provider = "prisma-client-js"  // 保持这个就好（兼容旧风格，无需 adapter）
}

model Product {
  id           String     @id @default(uuid())
  name        String
  company     String
  description String
  featured   Boolean
  image       String
  price       Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  clerkId  String
}